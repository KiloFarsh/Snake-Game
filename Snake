<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>snake · dark</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: #2a2a2a;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
        }

        .game {
            text-align: center;
            padding: 28px;
            background: #333333;
            border-radius: 12px;
            border: 1px solid #444;
        }

        canvas {
            display: block;
            margin: 0 auto;
            border: 1px solid #3d3d3d;
            background: #383838;
            border-radius: 8px;
        }

        .info {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 18px;
            gap: 20px;
        }

        .score {
            font-size: 16px;
            font-weight: 400;
            color: #999;
            letter-spacing: 0.3px;
        }

        .score span {
            color: #ddd;
            font-weight: 500;
        }

        .controls {
            display: flex;
            gap: 10px;
        }

        button {
            background: #3a3a3a;
            border: 1px solid #4a4a4a;
            color: #bbb;
            font-size: 14px;
            font-weight: 400;
            padding: 7px 18px;
            cursor: pointer;
            transition: all 0.12s;
            border-radius: 6px;
            text-transform: lowercase;
            letter-spacing: 0.3px;
        }

        button:hover {
            background: #444;
            border-color: #555;
            color: #ddd;
        }

        button:active {
            background: #333;
        }

        .hint {
            margin-top: 16px;
            color: #777;
            font-size: 12px;
        }

        .hint kbd {
            font-family: inherit;
            color: #999;
            margin: 0 3px;
        }
    </style>
</head>
<body>
<div class="game">
    <canvas id="snakeCanvas" width="400" height="400"></canvas>
    
    <div class="info">
        <div class="score">score: <span id="scoreDisplay">0</span></div>
        <div class="controls">
            <button id="pauseButton">pause</button>
            <button id="restartButton">restart</button>
        </div>
    </div>
    <div class="hint">
        <kbd>←↑↓→</kbd> or <kbd>WASD</kbd> · <kbd>space</kbd> / <kbd>P</kbd> to pause
    </div>
</div>

<script>
    (function(){
        "use strict";

        const GRID_SIZE = 20;
        const COLS = 20;
        const ROWS = 20;
        const TICK_INTERVAL_MS = 140;

        const canvas = document.getElementById('snakeCanvas');
        const ctx = canvas.getContext('2d');
        const scoreSpan = document.getElementById('scoreDisplay');
        const pauseButton = document.getElementById('pauseButton');

        let snake = [];
        let food = { x: 6, y: 10 };
        let direction = 'RIGHT';
        let nextDirection = 'RIGHT';
        let score = 0;
        let gameActive = false;
        let gameOverFlag = false;
        let winFlag = false;
        let paused = false;
        let gameLoopInterval = null;

        function generateRandomFood() {
            if (snake.length >= COLS * ROWS) return null;
            const snakeSet = new Set(snake.map(c => `${c.x},${c.y}`));
            const free = [];
            for (let i = 0; i < COLS; i++) {
                for (let j = 0; j < ROWS; j++) {
                    if (!snakeSet.has(`${i},${j}`)) free.push({ x: i, y: j });
                }
            }
            return free[Math.floor(Math.random() * free.length)];
        }

        function updatePauseButton() {
            pauseButton.textContent = paused ? 'resume' : 'pause';
        }

        function initGame() {
            if (gameLoopInterval) clearInterval(gameLoopInterval);
            snake = [{ x: 9, y: 10 }, { x: 8, y: 10 }, { x: 7, y: 10 }];
            direction = 'RIGHT';
            nextDirection = 'RIGHT';
            score = 0;
            gameActive = true;
            gameOverFlag = false;
            winFlag = false;
            paused = false;
            updatePauseButton();
            updateScore();
            food = generateRandomFood() || { x: 5, y: 5 };
            drawCanvas();
            gameLoopInterval = setInterval(gameTick, TICK_INTERVAL_MS);
        }

        function stopGame(isWin = false) {
            gameActive = false;
            gameOverFlag = !isWin;
            winFlag = isWin;
            paused = false;
            updatePauseButton();
            clearInterval(gameLoopInterval);
            gameLoopInterval = null;
            drawCanvas();
        }

        function togglePause() {
            if (!gameActive) return;
            paused = !paused;
            updatePauseButton();
            drawCanvas();
        }

        function updateScore() {
            scoreSpan.textContent = score;
        }

        function moveSnake() {
            if (!gameActive || paused) return false;

            const opposite = { 'UP':'DOWN', 'DOWN':'UP', 'LEFT':'RIGHT', 'RIGHT':'LEFT' };
            if (nextDirection && opposite[nextDirection] !== direction) {
                direction = nextDirection;
            }

            const head = snake[0];
            let newHead = { ...head };
            switch (direction) {
                case 'RIGHT': newHead.x++; break;
                case 'LEFT':  newHead.x--; break;
                case 'UP':    newHead.y--; break;
                case 'DOWN':  newHead.y++; break;
            }

            if (newHead.x < 0 || newHead.x >= COLS || newHead.y < 0 || newHead.y >= ROWS) {
                stopGame(false);
                return false;
            }

            const isEating = (newHead.x === food.x && newHead.y === food.y);
            let newSnake = [newHead, ...snake];
            if (!isEating) newSnake.pop();

            const headPos = newSnake[0];
            if (newSnake.slice(1).some(s => s.x === headPos.x && s.y === headPos.y)) {
                stopGame(false);
                return false;
            }

            snake = newSnake;

            if (isEating) {
                score++;
                updateScore();
                const newFood = generateRandomFood();
                if (!newFood) {
                    stopGame(true);
                    return false;
                }
                food = newFood;
            }

            if (snake.length === COLS * ROWS) {
                stopGame(true);
                return false;
            }

            return true;
        }

        function gameTick() {
            if (gameActive && !paused) {
                moveSnake();
                drawCanvas();
            }
        }

        function drawCanvas() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            // Grid
            ctx.strokeStyle = '#4a4a4a';
            ctx.lineWidth = 0.6;
            for (let i = 0; i <= COLS; i++) {
                ctx.beginPath();
                ctx.moveTo(i * GRID_SIZE, 0);
                ctx.lineTo(i * GRID_SIZE, canvas.height);
                ctx.stroke();
            }
            for (let i = 0; i <= ROWS; i++) {
                ctx.beginPath();
                ctx.moveTo(0, i * GRID_SIZE);
                ctx.lineTo(canvas.width, i * GRID_SIZE);
                ctx.stroke();
            }

            // Food
            if (food) {
                const x = food.x * GRID_SIZE;
                const y = food.y * GRID_SIZE;
                ctx.fillStyle = '#d47070';
                ctx.beginPath();
                ctx.arc(x + GRID_SIZE/2, y + GRID_SIZE/2, GRID_SIZE/2 - 2, 0, 2*Math.PI);
                ctx.fill();
                // subtle highlight
                ctx.fillStyle = '#e09090';
                ctx.beginPath();
                ctx.arc(x + GRID_SIZE/2 - 2, y + GRID_SIZE/2 - 2, 2.5, 0, 2*Math.PI);
                ctx.fill();
            }

            // Snake
            snake.forEach((seg, i) => {
                const x = seg.x * GRID_SIZE;
                const y = seg.y * GRID_SIZE;
                const isHead = i === 0;
                ctx.fillStyle = isHead ? '#7aaa7a' : '#5a8a6a';
                const padding = isHead ? 2 : 3;
                ctx.beginPath();
                ctx.roundRect(x + padding, y + padding, GRID_SIZE - padding*2, GRID_SIZE - padding*2, 4);
                ctx.fill();
                
                // Eyes on head
                if (isHead) {
                    ctx.fillStyle = '#eee';
                    ctx.beginPath();
                    ctx.arc(x + 7, y + 7, 2.2, 0, 2*Math.PI);
                    ctx.arc(x + 13, y + 7, 2.2, 0, 2*Math.PI);
                    ctx.fill();
                    ctx.fillStyle = '#333';
                    ctx.beginPath();
                    ctx.arc(x + 8, y + 6, 1.2, 0, 2*Math.PI);
                    ctx.arc(x + 14, y + 6, 1.2, 0, 2*Math.PI);
                    ctx.fill();
                }
            });

            // Pause overlay
            if (paused && gameActive) {
                ctx.fillStyle = 'rgba(40, 40, 40, 0.8)';
                ctx.fillRect(0, 0, canvas.width, canvas.height);
                ctx.font = '400 26px -apple-system, BlinkMacSystemFont, sans-serif';
                ctx.fillStyle = '#aaa';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                ctx.fillText('paused', canvas.width/2, canvas.height/2 - 5);
                ctx.font = '13px -apple-system, sans-serif';
                ctx.fillStyle = '#888';
                ctx.fillText('space or P to resume', canvas.width/2, canvas.height/2 + 25);
                ctx.textAlign = 'left';
            }

            // Game over / win
            if (!gameActive) {
                ctx.font = '400 24px -apple-system, BlinkMacSystemFont, sans-serif';
                ctx.fillStyle = '#bbb';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                ctx.fillText(winFlag ? 'you win' : 'game over', canvas.width/2, canvas.height/2 - 10);
                ctx.font = '13px -apple-system, sans-serif';
                ctx.fillStyle = '#888';
                ctx.fillText('press restart', canvas.width/2, canvas.height/2 + 20);
                ctx.textAlign = 'left';
            }
        }

        // Helper for rounded rectangles
        CanvasRenderingContext2D.prototype.roundRect = function(x, y, w, h, r) {
            if (w < 2 * r) r = w / 2;
            if (h < 2 * r) r = h / 2;
            this.moveTo(x + r, y);
            this.lineTo(x + w - r, y);
            this.quadraticCurveTo(x + w, y, x + w, y + r);
            this.lineTo(x + w, y + h - r);
            this.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
            this.lineTo(x + r, y + h);
            this.quadraticCurveTo(x, y + h, x, y + h - r);
            this.lineTo(x, y + r);
            this.quadraticCurveTo(x, y, x + r, y);
            return this;
        };

        function handleKeyDown(e) {
            const key = e.key;
            
            // Prevent page scrolling with arrows and WASD
            const controlKeys = ["ArrowUp", "ArrowDown", "ArrowLeft", "ArrowRight", "w", "W", "s", "S", "a", "A", "d", "D", " ", "p", "P"];
            if (controlKeys.includes(key)) {
                e.preventDefault();
            }

            // Pause handling
            if (key === ' ' || key === 'p' || key === 'P') {
                if (gameActive) togglePause();
                return;
            }

            if (!gameActive || paused) return;

            // Direction handling - FIXED: check both lowercase and uppercase for WASD
            let newDir = null;
            if (key === 'ArrowRight' || key === 'd' || key === 'D') newDir = 'RIGHT';
            else if (key === 'ArrowLeft' || key === 'a' || key === 'A') newDir = 'LEFT';
            else if (key === 'ArrowUp' || key === 'w' || key === 'W') newDir = 'UP';
            else if (key === 'ArrowDown' || key === 's' || key === 'S') newDir = 'DOWN';
            else return;

            const opposite = { 'UP':'DOWN', 'DOWN':'UP', 'LEFT':'RIGHT', 'RIGHT':'LEFT' };
            if (opposite[newDir] !== direction) {
                nextDirection = newDir;
            }
        }

        document.getElementById('restartButton').addEventListener('click', initGame);
        pauseButton.addEventListener('click', () => { if (gameActive) togglePause(); });
        window.addEventListener('keydown', handleKeyDown);
        window.addEventListener('load', initGame);
    })();
</script>
</body>
</html>
